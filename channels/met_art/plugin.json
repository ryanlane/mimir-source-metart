{
  "id": "com.metmuseum.art",
  "name": "Met Museum Art",
  "description": "Displays artworks from The Metropolitan Museum of Art's open collection. Browse by department, keyword search, or highlights gallery. No API key required.",
  "version": "1.3.0",
  "type": "embedded",
  "entry_point": "channel.py",
  "class_name": "MetArtChannel",
  "icon": "landmark",
  "author": "Ryan Lane",
  "tags": [
    "art",
    "museum",
    "met",
    "gallery",
    "paintings",
    "public-domain"
  ],
  "schemaVersion": "2.4",
  "settingsType": "advanced",
  "config": {
    "supports_upload": false,
    "supports_subchannels": true,
    "requires_api_key": false
  },
  "requirements": {
    "python": ">=3.8",
    "dependencies": [
      "fastapi",
      "pillow",
      "requests",
      "jinja2"
    ]
  },
  "user_data_dirs": [
    "data"
  ],
  "update_schedule": {
    "unit": "hours",
    "duration": 1,
    "settings_driven": false
  },
  "settings": {
    "defaults": {
      "fit_mode": "letterbox",
      "image_quality": "primary",
      "cache_max_per_gallery": 200,
      "refresh_interval_hours": 168
    },
    "schema": {
      "type": "object",
      "properties": {
        "fit_mode": {
          "type": "string",
          "enum": ["letterbox", "crop", "stretch"],
          "title": "Fit Mode",
          "description": "How to fit the artwork image to the display resolution",
          "default": "letterbox"
        },
        "image_quality": {
          "type": "string",
          "enum": ["primary", "small"],
          "title": "Image Quality",
          "description": "primary = full-resolution original, small = web-large thumbnail (faster)",
          "default": "primary"
        },
        "cache_max_per_gallery": {
          "type": "integer",
          "minimum": 20,
          "maximum": 500,
          "title": "Max Artworks per Gallery",
          "description": "How many artworks to cache per gallery (more = more variety, slower initial build)",
          "default": 200
        },
        "refresh_interval_hours": {
          "type": "integer",
          "minimum": 1,
          "title": "Cache Refresh Interval (hours)",
          "description": "How often to re-fetch the artwork list from the Met API (default: weekly)",
          "default": 168
        }
      }
    }
  },
  "endpoints": [
    { "path": "/manifest", "method": "GET", "description": "Get channel manifest and capabilities" },
    { "path": "/subchannels", "method": "GET", "description": "List configured galleries" },
    { "path": "/request-image", "method": "POST", "description": "Get a random artwork as raw image bytes" },
    { "path": "/settings", "method": "GET", "description": "Get channel settings" },
    { "path": "/settings", "method": "PUT", "description": "Update channel settings" },
    { "path": "/status", "method": "GET", "description": "Get cache and gallery status" },
    { "path": "/refresh", "method": "POST", "description": "Trigger artwork cache refresh" },
    { "path": "/galleries", "method": "POST", "description": "Create a new gallery" },
    { "path": "/galleries/{gallery_id}", "method": "PUT", "description": "Update an existing gallery" },
    { "path": "/galleries/{gallery_id}", "method": "DELETE", "description": "Delete a gallery" },
    { "path": "/departments", "method": "GET", "description": "List Met Museum departments" }
  ]
}
